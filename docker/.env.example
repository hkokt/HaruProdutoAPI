HTTP_PORT=80
POSTGRES_PORT=5432

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_local_password

APP_DB_NAME=haru_product
APP_DB_USER=haru
APP_DB_PASSWORD=haru_local_password

KEYCLOAK_VERSION=26.3.3
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_local_password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_local_password
KEYCLOAK_REALM=haru
KEYCLOAK_CLIENT_ID=haru-api
KEYCLOAK_AUDIENCE=haru-api
KEYCLOAK_PUBLIC_URL=http://localhost/auth

ELASTICSEARCH_VERSION=9.4.2
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_PRODUCTS_INDEX=haru-products-v2
ELASTICSEARCH_REINDEX_ON_STARTUP=true
ELASTICSEARCH_CONNECT_TIMEOUT=2s
ELASTICSEARCH_READ_TIMEOUT=5s
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
ELASTICSEARCH_MEMORY_LIMIT=1g
ELASTICSEARCH_CPUS=1.0

SPRING_PROFILES_ACTIVE=docker
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport
