HTTP_PORT=80
POSTGRES_PORT=5432

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_local_password

APP_DB_NAME=haru_produto
APP_DB_USER=haru
APP_DB_PASSWORD=haru_local_password

KEYCLOAK_VERSION=26.3.3
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak_local_password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_local_password
KEYCLOAK_REALM=haru
KEYCLOAK_CLIENT_ID=haru-api
KEYCLOAK_PUBLIC_URL=http://localhost/auth

SPRING_PROFILES_ACTIVE=docker
JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+UseContainerSupport
