{
  "realm": "haru",
  "enabled": true,
  "displayName": "Haru Produto API",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "defaultRoles": [
    "offline_access",
    "uma_authorization",
    "customer"
  ],
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "haru-api",
      "name": "Haru API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost/*",
        "https://bookish-fiesta-vjv9rggj4jjcxrvw-80.app.github.dev/*"
      ],
      "webOrigins": [
        "http://localhost",
        "https://bookish-fiesta-vjv9rggj4jjcxrvw-80.app.github.dev"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost/*##https://bookish-fiesta-vjv9rggj4jjcxrvw-80.app.github.dev/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "basic",
        "email"
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin", "description": "Administrador da API" },
      { "name": "customer", "description": "Cliente da API" }
    ]
  }
}
