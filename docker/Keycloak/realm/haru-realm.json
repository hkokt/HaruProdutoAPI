{
  "realm": "haru",
  "enabled": true,
  "displayName": "Haru Product API",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "defaultRoles": [
    "offline_access",
    "uma_authorization",
    "customer"
  ],
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "haru-api",
      "name": "Haru API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost/*",
        "https://bookish-fiesta-vjv9rggj4jjcxrvw-80.app.github.dev/*"
      ],
      "webOrigins": [
        "http://localhost",
        "https://bookish-fiesta-vjv9rggj4jjcxrvw-80.app.github.dev"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost/*##https://bookish-fiesta-vjv9rggj4jjcxrvw-80.app.github.dev/*"
      },
      "protocolMappers": [
        {
          "name": "haru-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "haru-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "roles",
        "profile",
        "basic",
        "email"
      ]
    }
  ],
  "roles": {
    "realm": [
      { "name": "admin", "description": "API administrator" },
      { "name": "customer", "description": "API customer" }
    ]
  }
}
